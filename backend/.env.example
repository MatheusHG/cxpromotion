# Server
PORT=4000
NODE_ENV=development
JWT_SECRET=troque-isso-em-producao-use-uma-string-bem-longa-aleatoria
JWT_EXPIRES_IN=8h

# Postgres (auth dos atendentes)
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=cx_promocoes

# ClickHouse (analytics — banco majorsports)
CLICKHOUSE_URL=https://your-cluster.clickhouse.cloud:8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# CORS — origem do frontend
FRONTEND_ORIGIN=http://localhost:5173

# XtremePush
XTREMEPUSH_REGION=us
XTREMEPUSH_API_TOKEN=
